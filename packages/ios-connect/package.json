{
  "name": "@tbana/ios-connect",
  "private": true,
  "type": "module",
  "main": "./ts/index.ts",
  "types": "./ts/index.ts",
  "exports": {
    ".": "./ts/index.ts"
  },
  "scripts": {
    "build": "napi build --platform --release --output-dir ./dist",
    "build:debug": "napi build --platform --output-dir ./dist",
    "postinstall": "bun run scripts/build-native.ts"
  },
  "dependencies": {
    "bplist-parser": "^0.3.2",
    "jszip": "^3.10.1",
    "plist": "^3.1.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "@types/folder-hash": "^4.0.4",
    "@types/plist": "^3.0.5",
    "folder-hash": "^4.0.4"
  },
  "napi": {
    "binaryName": "tbana-isideload",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  }
}
